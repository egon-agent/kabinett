FROM node:22-bookworm-slim

WORKDIR /app

COPY apps/europeana-visual-service/package.json /app/apps/europeana-visual-service/package.json
RUN npm install --prefix /app/apps/europeana-visual-service

COPY apps/europeana-visual-service /app/apps/europeana-visual-service
COPY apps/europeana-reference-ui /app/apps/europeana-reference-ui
COPY packages/europeana-visual-core /app/packages/europeana-visual-core
COPY apps/europeana-visual-demo-start.mjs /app/apps/europeana-visual-demo-start.mjs
COPY apps/europeana-visual-service/data/europeana-demo.db /app/data/europeana-demo.db

ENV NODE_ENV=production
ENV DATABASE_PATH=/app/data/europeana-demo.db
ENV KABINETT_CLIP_ALLOW_REMOTE=1
ENV EUROPEANA_VISUAL_ALLOWED_ORIGINS=*
ENV VISUAL_SERVICE_URL=http://127.0.0.1:4318

EXPOSE 4320

CMD ["node", "/app/apps/europeana-visual-demo-start.mjs"]
