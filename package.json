{
  "name": "kabinett",
  "private": true,
  "description": "Kabinett \u2014 Discover Swedish art",
  "scripts": {
    "dev": "pnpm --filter @kabinett/web dev",
    "sync": "pnpm --filter @kabinett/data sync",
    "build": "pnpm --filter @kabinett/web build",
    "demo:europeana:service": "pnpm --filter @kabinett/europeana-visual-service start",
    "demo:europeana:ui": "pnpm --filter @kabinett/europeana-reference-ui start",
    "demo:europeana:build-db": "pnpm --filter @kabinett/europeana-visual-service build:demo-db",
    "demo:europeana:deploy:fly": "flyctl deploy --config fly.europeana-demo.toml"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
